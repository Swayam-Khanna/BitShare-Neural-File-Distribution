# BitShare Backend Configuration

# Server Settings
PORT=8000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (e.g. http://localhost:5173,https://yourdomain.com)
ALLOWED_ORIGINS=http://localhost:5173

# Database configuration
MONGO_URI=mongodb://localhost:27017/bitshare

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth (for Login/Signup)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Pusher Real-Time (Required for Vercel)
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret_here
PUSHER_CLUSTER=your_pusher_cluster_here

# Stripe Payments (for Pro/Enterprise upgrades)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (for payment redirection)
FRONTEND_URL=http://localhost:5173
